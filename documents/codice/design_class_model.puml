@startuml
left to right direction

' ======================
' Classes
' ======================
class City {
  - name: String
  - grid: CityGrid
  - state: CityState
  - activePolicy: Policy
  + City(name: String, size: int)
  + getGrid(): CityGrid
  + getState(): CityState
  + getPolicy(): Policy
 
}

class CityGrid {
  - size: int
  - cells: Cell[][]
  + CityGrid(size: int)
  + place(x: int, y: int, entity: PlaceableEntity): boolean
  + remove(x: int, y: int): void
  + getCell(x: int, y: int): Cell
}

class Cell {
  - x: int
  - y: int
  - entity: PlaceableEntity  
  + Cell(x: int, y: int)
  + isEmpty(): boolean
  + placeEntity(entity: PlaceableEntity): void
  + getEntity(): PlaceableEntity
  + clear(): void
}

class CityState {
  - budget: int
  - population: int
  - pollution: int
  - happiness: int  
  + CityState(initialBudget: int)
  + applyEffects(effects: Effect): void
  + getBudget(): int
  + getPopulation(): int
  + getPollution(): int
  + getHappiness(): int
}

class Effect {
  - budget: int
  - population: int
  - pollution: int
  - happiness: int
  + Effect(budget: int, population: int, pollution: int, happiness: int)
  + getBudget(): int
  + getPopulation(): int
  + getPollution(): int
  + getHappiness(): int
  + printEffects() : String 
}

abstract class PlaceableEntity {
  # name: String
  # effects: Effect  
  + PlaceableEntity(name: String)
  + getType(): String
}

abstract class Building {
  + Building(name: String)
}

class ResidentialBuilding {
  + ResidentialBuilding()
  + canBePlaced(x: int, y: int): boolean
}

class IndustrialBuilding {
  + IndustrialBuilding()
}

class CommercialBuilding {
  + CommercialBuilding()
}

abstract class Infrastructure {
  + Infrastructure(name: String)
}

class PowerPlant {
  + PowerPlant()
}

class Park {
  + Park()
}

class Road {
  + Road()
}

interface Policy {
  + getEffects(): Effect
  + getName(): String
}

class EnvironmentalTaxPolicy{
  - effects : Effect
  + EnvironmentalTaxPolicy()
}

class IndustrialExpansionPolicy{
  - effects : Effect
  + IndustrialExpansionPolicy()
}


' ======================
'Simulation
' ======================

class Controller {
  + placeEntity(entity: Entity, x: int, y: int, city: City): boolean
  + applyPolicy(policy: Policy, city: City): boolean
  + removeEntity(x: int, y: int, city: City): void
}

class TickEngine {
  - currentTick: int
  + advanceTick(city: City): void
  + getCurrentTick(): int
}

class SaveManager {
  + save(city: City, filepath: String): boolean
  + load(filepath: String): City
}

' ======================
' Structural Relations
' ======================

City "1" *-- "1" CityGrid : contains
City "1" *-- "1" CityState : owns
City "0..1" o-- "0..*" Policy : activates

CityGrid "1" *-- "1..*" Cell : composed of

Cell "0..1" -- "0..1" PlaceableEntity : hosts

PlaceableEntity "0..*" o-- "1" Effect : produces

' ======================
' Inheritance
' ======================

PlaceableEntity <|-- Building
PlaceableEntity <|-- Infrastructure

Building <|-- ResidentialBuilding
Building <|-- IndustrialBuilding
Building <|-- CommercialBuilding

Infrastructure <|-- PowerPlant
Infrastructure <|-- Park
Infrastructure <|-- Road

Policy <|.. EnvironmentalTaxPolicy
Policy <|.. IndustrialExpansionPolicy

Controller --> City
TickEngine --> City
SaveManager --> City

' ======================
' Notes
' ======================

note right of Effect
Represents modifications
applied to the CityState
(e.g. population,
pollution, budget).
end note

note bottom of Policy
Policies alter the way
simulation effects are
applied during a tick.
end note
@enduml
